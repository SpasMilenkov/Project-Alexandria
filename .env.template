# ============================================================
# Alexandria — Environment Configuration Template
# Copy this file to .env and fill in all values
# NEVER commit .env to source control
# ============================================================

# Database
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Admin account credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=

# RabbitMQ
RABBITMQ_USER=alexandria
RABBITMQ_PASSWORD=
DOCUMENT_WORKER_RABBITMQ_PASSWORD=
MEDIA_WORKER_RABBITMQ_PASSWORD=
RABBITMQ_VHOST=alexandria

# Garage S3
# These come from the garage-init container output
# When the garage init container finishes all the relevant credentials should be in the init-output directory
# located at the root level of the project.
# Alterntaively you can run:`
# docker logs alexandria-garage-init
# and copy the Key ID and Secret key for alexandria-master-key
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=
GARAGE_S3_ACCESS_KEY=placeholder
GARAGE_S3_SECRET_KEY=placeholder
GARAGE_S3_WORKER_ACCESS_KEY=placeholder
GARAGE_S3_WORKER_SECRET_KEY=placeholder
GARAGE_S3_PUBLIC_ENDPOINT=

# JWT
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# CSRF
# Generate with: openssl rand -base64 32
CSRF_SECRET=

# CORS
# The public-facing origin your frontend is served from
# Dev:        https://localhost
# Production: https://yourdomain.com
# Multiple:   use index notation in appsettings instead (see appsettings.Production.json)
CORS_ALLOWED_ORIGINS__0=
CORS_ALLOWED_ORIGINS__1=

# Garage init
# Origin the browser uploads from — must match CORS_ALLOWED_ORIGINS
CORS_ORIGIN=

# Grafana
GRAFANA_USER=admin
# Generate with: openssl rand -base64 16
GRAFANA_PASSWORD=

