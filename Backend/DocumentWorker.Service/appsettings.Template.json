{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "ConnectionStrings": {
    "AlexandriaPostgres": "Host=postgres;Port=5432;Database=alexandria_prod;Username=alexandria_user;Password=${DB_PASSWORD}"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "alexandria",
    "UserName": "document_worker_user",
    "ChannelPoolSize": 10,
    "Consumer": {
      "QueueName": "document-queue",
      "PrefetchCount": 10,
      "AutoAck": false,
      "Concurrency": 1
    }
  },
  "S3Storage": {
    "Provider": "Garage",
    "Endpoint": "",
    "PublicEndpoint": "",
    "UseHttps": true,
    "Region": "garage",
    "UploadBucket": "alexandria-files",
    "PreviewBucket": "alexandria-previews",
    "TempBucket": "alexandria-temp",
    "ProviderSettings": {
      "Garage": {
        "Region": "garage",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false
      }
    }
  }
}
