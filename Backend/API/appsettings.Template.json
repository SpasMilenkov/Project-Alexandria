{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "AlexandriaPostgres": "Host=postgres;Port=5432;Database=alexandria_prod;Username=alexandria_user;Password=${DB_PASSWORD}"
  },
  "S3Storage": {
    "Provider": "Garage",
    "Endpoint": "",
    "PublicEndpoint": "",
    "UseHttps": true,
    "Region": "garage",
    "UploadBucket": "alexandria-files",
    "PreviewBucket": "alexandria-previews",
    "TempBucket": "alexandria-temp",
    "ImagesBucket": "alexandria-images",
    "ProviderSettings": {
      "Garage": {
        "Region": "garage",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false,
        "MetricsUrl": "",
        "MetricsToken": ""
      }
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "alexandria",
    "ChannelPoolSize": 10,
    "Producer": {
      "QueueName": "my-queue",
      "PrefetchCount": 10,
      "AutoAck": false,
      "Concurrency": 1
    }
  },
  "Jwt": {
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Csrf": {
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": ["https://localhost"]
  },
  "HealthChecks": {
    "Database": { "Enabled": true },
    "Storage": { "Enabled": true },
    "MessageBroker": { "Enabled": true },
    "Workers": [
      {
        "Name": "DocumentWorker",
        "Url": "http://document-worker:8080/health",
        "Enabled": true
      },
      {
        "Name": "MediaWorker",
        "Url": "http://media-worker:8080/health",
        "Enabled": true
      }
    ]
  }
}
