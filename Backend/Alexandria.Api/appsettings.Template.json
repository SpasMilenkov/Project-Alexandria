{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext"]
  },
  "S3Storage": {
    "Provider": "Garage",
    "Endpoint": "http://garage:3900",
    "UseHttps": true,
    "Region": "garage",
    "UploadBucket": "alexandria-files",
    "PreviewBucket": "alexandria-previews",
    "TempBucket": "alexandria-temp",
    "ImagesBucket": "alexandria-images",
    "ProviderSettings": {
      "Garage": {
        "Region": "garage",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false,
        "MetricsUrl": "http://garage:3903/metrics"
      }
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "alexandria",
    "ChannelPoolSize": 10,
    "Producer": {
      "QueueName": "my-queue",
      "PrefetchCount": 10,
      "AutoAck": false,
      "Concurrency": 1
    }
  },
  "Jwt": {
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Csrf": {
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": ["https://localhost"]
  },
  "HealthChecks": {
    "Database": { "Enabled": true },
    "Storage": { "Enabled": true },
    "MessageBroker": { "Enabled": true },
    "Workers": [
      {
        "Name": "DocumentWorker",
        "Url": "http://document-worker:8080/health",
        "Enabled": true
      },
      {
        "Name": "MediaWorker",
        "Url": "http://media-worker:8080/health",
        "Enabled": true
      }
    ]
  }
}
