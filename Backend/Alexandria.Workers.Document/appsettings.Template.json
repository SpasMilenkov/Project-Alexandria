{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "alexandria",
    "ChannelPoolSize": 10,
    "Consumer": {
      "QueueName": "document-queue",
      "PrefetchCount": 10,
      "AutoAck": false,
      "Concurrency": 1
    }
  },
  "S3Storage": {
    "Provider": "Garage",
    "Endpoint": "http://garage:3900",
    "UseHttps": true,
    "Region": "garage",
    "UploadBucket": "alexandria-files",
    "PreviewBucket": "alexandria-previews",
    "TempBucket": "alexandria-temp",
    "ProviderSettings": {
      "Garage": {
        "Region": "garage",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false
      }
    }
  }
}
