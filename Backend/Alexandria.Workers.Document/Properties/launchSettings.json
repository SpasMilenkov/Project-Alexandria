{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "DocumentWorker (RustFS)": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development",
        "S3Storage__Provider": "RustFS"
      }
    },
    "DocumentWorker (MinIO)": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development",
        "S3Storage__Provider": "MinIO"
      }
    },
    "DocumentWorker (Garage)": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development",
        "S3Storage__Provider": "Garage"
      }
    }
  }
}
