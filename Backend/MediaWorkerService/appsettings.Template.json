{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "AlexandriaPostgres": "Host=localhost; Port=5432; Database=alexandria_prod; Username=alexandria_user; Password=Alexandria_admin"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "media_worker_user",
    "VirtualHost": "alexandria",
    "ChannelPoolSize": 10,
    "Consumer": {
      "QueueName": "content-queue",
      "PrefetchCount": 10,
      "AutoAck": false,
      "Concurrency": 1
    }
  },
  "S3Storage": {
    "Provider": "Garage",
    "Endpoint": "",
    "PublicEndpoint": "",
    "UseHttps": true,
    "Region": "garage",
    "UploadBucket": "alexandria-files",
    "PreviewBucket": "alexandria-previews",
    "TempBucket": "alexandria-temp",

    "ProviderSettings": {
      "Garage": {
        "Region": "garage",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false
      },
      "RustFS": {
        "Region": "us-east-1",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false
      },
      "MinIO": {
        "Region": "us-east-1",
        "ForcePathStyle": true,
        "UseAccelerateEndpoint": false,
        "UseDualstackEndpoint": false
      }
    }
  }
}
