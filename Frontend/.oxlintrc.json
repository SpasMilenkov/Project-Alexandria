{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  "plugins": ["typescript", "vue"],

  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "style": "warn"
  },

  "rules": {
    "no-console": "warn",
    "no-debugger": "error"
  },

  "settings": {
    "vue": {
      "scriptSetup": true
    }
  },

  "env": {
    "builtin": true
  },

  "ignorePatterns": ["node_modules", "dist", ".output", ".nuxt"]
}
