{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  "plugins": ["typescript", "vue"],

  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "style": "warn"
  },

  "rules": {
    "no-console": "error",
    "no-debugger": "error",
    "no-magic-numbers": "off",
    "new-cap": "off",
    "id-length": "off",
    "curly": "allow",
    "capitalized-comments": "allow",
    "no-ternary": "allow",
    "eslint/sort-imports": [
      "warn",
      {
        "ignoreDeclarationSort": true,
        "ignoreMemberSort": false
      }
    ],
    "max-lines": [
      "warn",
      {
        "max": 500
      }
    ],
    "max-statements": ["warn", { "max": 20, "ignoreTopLevelFunctions": true }],
    "max-lines-per-function": ["warn", { "skipBlankLines": true, "skipComments": true, "max": 100 }]
  },

  "settings": {
    "vue": {
      "scriptSetup": true
    }
  },

  "env": {
    "builtin": true
  },

  "ignorePatterns": ["node_modules", "dist", ".output", ".nuxt"]
}
